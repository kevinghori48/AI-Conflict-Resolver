                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    console.log('User 2 Token:', jsonData.token);",
                  "    console.log('User 2 ID:', jsonData.user._id);",
                  "    console.log('Save this token for the second user!');",

              ]
            },
            "description": "Get relationship-specific questions. Options: couple, roommates, friends, family, workplace, other"
          },
          "response": []
        },
        {
          "name": "Create Dispute",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('disputeId', jsonData.dispute_id);",
                  "    pm.collectionVariables.set('inviteCode', jsonData.invite_code);",
                  "    console.log('Dispute ID:', jsonData.dispute_id);",
                  "    console.log('Invite Code:', jsonData.invite_code);",
                  "}"
                ],
                "type": "text/javascript",
                "id": "ceadfcbf-8178-4777-bbe4-9a5b49a36cb6"
              }
            }
          ],
          "id": "06984c1d-fe1d-4546-9222-2c0ff737b432",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dispute_name\": \"Apartment Cleaning Schedule\",\n  \"relationship_type\": \"roommates\",\n  \"relationship_importance\": \"high\",\n  \"goal\": \"Create a fair cleaning schedule that works for both of us\",\n  \"non_negotiables\": \"Kitchen must be cleaned daily\",\n  \"avoid_topics\": \"Past conflicts about rent\",\n  \"urgency\": \"1_week\",\n  \"relationship_questions\": [\n    {\n      \"question\": \"How long have you lived together?\",\n      \"answer\": \"6 months\"\n    },\n    {\n      \"question\": \"What are the main issues?\",\n      \"answer\": \"Dishes pile up in the sink\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/official-dispute/create",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "official-dispute",
                "create"
              ]
            },
            "description": "Create a new dispute (User 1)\n\n{{baseUrl}}/official-dispute/create\n\nheader  \nkey :Content-Type\n\nvalue :application/json"
          },
          "response": []
        }
      ],
      "id": "61374e32-5a7d-469b-9510-4bef575b604c"

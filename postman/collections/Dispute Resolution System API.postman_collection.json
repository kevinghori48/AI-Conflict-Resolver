      "name": "Screen 1 & 2 - Create Dispute",
      "item": [
        {
          "name": "Get Relationship Questions",
          "id": "c1850fab-05d8-470f-838e-db26a5180f9c",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/official-dispute/questions/couple",
              "host": [
                "{{baseUrl}}"
              ],
